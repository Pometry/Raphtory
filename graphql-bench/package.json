{
    "name": "bench",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "module": "./dist/index.js",
    "files": [
        "dist"
    ],
    "scripts": {
        "prebuild": "genql --schema ../raphtory-graphql/schema.graphql --output src/__generated",
        "build": "tsc --noEmit && tsup",
        "bench": "pnpm build && K6_WEB_DASHBOARD=true K6_WEB_DASHBOARD_EXPORT=report.html k6 run --out csv=output.csv.gz dist/bench.js"
    },
    "devDependencies": {
        "@genql/cli": "^6.3.3",
        "@types/k6": "^1.7.0",
        "@types/node": "^25.5.0",
        "concurrently": "^9.2.1",
        "tsup": "8.3.5",
        "typescript": "^6.0.2"
    },
    "dependencies": {
        "@google-cloud/compute": "^6.9.0",
        "dotenv": "^17.3.1",
        "node-ssh": "^13.2.1",
        "zod": "^4.3.6"
    }
}
